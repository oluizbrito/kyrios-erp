                    <Platform Name="Win32">
                        <RemoteDir>Assets\</RemoteDir>
                        <RemoteName>Logo44x44.png</RemoteName>
                        <Overwrite>true</Overwrite>
                    </Platform>
                </DeployFile>
                <DeployFile LocalName="C:\Sistema\Retaguarda.exe" Configuration="Release" Class="ProjectOutput"/>
                <DeployFile LocalName="C:\Sistema\Retaguarda.exe" Configuration="Release" Class="ProjectOutput">
                    <Platform Name="Win32">
                        <RemoteName>Retaguarda.exe</RemoteName>
                        <Overwrite>true</Overwrite>
                    </Platform>
                </DeployFile>
                <DeployFile LocalName="C:\Users\LojadoDesenvolvedor\Downloads\Graph-Magnifier-icon (1).png" Configuration="Debug" Class="UWP_DelphiLogo44"/>
                <DeployFile LocalName="C:\Users\LojadoDesenvolvedor\Downloads\Graph-Magnifier-icon.png" Configuration="Debug" Class="UWP_DelphiLogo150"/>

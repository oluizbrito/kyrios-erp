    object TabSheet4: TTabSheet
      Caption = 'Novos Campos'
      ImageIndex = 3
      object MemoNovo: TMemo
        Left = 0
        Top = 0
        Width = 1322
        Height = 746
        Align = alClient
        CharCase = ecUpperCase
        Lines.Strings = (
          '-- #### LUIZ - 18/06/2025 ####'
          ''
          'CREATE TABLE VEICULO_ROTA_TIPO_DESPESA ('
          '    CODIGO INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,'
          '    DESCRICAO VARCHAR(100) NOT NULL UNIQUE'
          ');'
          ''
          ''
          'CREATE TABLE VEICULO_ROTA_DESPESA ('
          '    CODIGO INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,'
          ''
          '    ROTA_CODIGO INTEGER NOT NULL,'
          '    TIPO_DESPESA_CODIGO INTEGER NOT NULL,'
          '    FORNECEDOR_CODIGO INTEGER,'
          ''
          '    DESCRICAO VARCHAR(255),'
          '    VALOR DECIMAL(15,2) NOT NULL,'
          '    DATA_VENCIMENTO DATE NOT NULL,'
          '    OBSERVACAO VARCHAR(255),'
          ''
          '    COMPROVANTE_DOC BLOB SUB_TYPE 0,'
          '    IMPORTADO_FIN CHAR(1) DEFAULT '#39'N'#39','
          ''
          
            '    CONSTRAINT FK_VRD_ROTA FOREIGN KEY (ROTA_CODIGO) REFERENCES ' +
            'VEICULOS_ROTA(CODIGO),'
          
            '    CONSTRAINT FK_VRD_TIPO FOREIGN KEY (TIPO_DESPESA_CODIGO) REF' +
            'ERENCES VEICULO_ROTA_TIPO_DESPESA(CODIGO),'
          
            '    CONSTRAINT FK_VRD_FORN FOREIGN KEY (FORNECEDOR_CODIGO) REFER' +
            'ENCES PESSOA(CODIGO)'
          ');'
          ''
          ''
          '-- #### LUIZ - 17/06/2025 ####'
          ''
          'CREATE TABLE VEICULOS_ROTA ('
          '    CODIGO INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,'
          '    VEICULO_PLACA VARCHAR(10) NOT NULL,'
          '    ORIGEM VARCHAR(100),'
          '    DESTINO_FINAL VARCHAR(100),'
          '    DATA_SAIDA DATE,'
          '    HORA_SAIDA TIME,'
          '    DATA_CHEGADA DATE,'
          '    HORA_CHEGADA TIME,'
          '    KM_INICIAL NUMERIC(10,2) NOT NULL,'
          '    KM_FINAL NUMERIC(10,2),'
          '    OBSERVACAO VARCHAR(255),'
          
            '    STATUS VARCHAR(20), -- EX: PLANEJADA, EM_ANDAMENTO, CONCLUID' +
            'A'
          ''
          
            '    CONSTRAINT FK_VEICULOS_ROTA_VEICULO FOREIGN KEY (VEICULO_PLA' +
            'CA) REFERENCES VEICULOS_CAVALO(PLACA)'
          ');'
          ''
          'CREATE TABLE VEICULOS_ROTA_PARADA ('
          '    CODIGO INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,'
          '    ROTA_CODIGO INTEGER NOT NULL,'
          '    ORDEM INTEGER NOT NULL,'
          '    CLIENTE_CODIGO INTEGER NOT NULL,'
          '    ENDERECO_CLIENTE VARCHAR(255),'
          
            '    KM_DESTINO NUMERIC(10,2) NOT NULL, -- QUILOMETRAGEM NO OD'#212'ME' +
            'TRO AO CHEGAR NESTA PARADA'
          '    OBSERVACAO VARCHAR(255),'
          ''
          
            '    CONSTRAINT FK_VEICULOS_PARADA_ROTA FOREIGN KEY (ROTA_CODIGO)' +
            ' REFERENCES VEICULOS_ROTA(CODIGO),'
          
            '    CONSTRAINT FK_VEICULOS_PARADA_CLIENTE FOREIGN KEY (CLIENTE_C' +
            'ODIGO) REFERENCES CLIENTE(CODIGO)'
          ');'
          ''
          ''
          '-- #### LUIZ - 31/05/2025 ####'
          ''
          'CREATE TABLE VEICULO_MANUTENCAO_TIPO_SERVICO ('
          '    CODIGO INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,'
          '    NOME VARCHAR(100) NOT NULL UNIQUE,'
          '    DESCRICAO BLOB SUB_TYPE TEXT'
          ');'
          ''
          'ALTER TABLE VEICULO_MANUTENCAO ADD TIPO_SERVICO_CODIGO INTEGER;'
          ''
          
            'ALTER TABLE VEICULO_MANUTENCAO ADD CONSTRAINT FK_MANUTENCAO_TIPO' +
            '_SERVICO'
          
            'FOREIGN KEY (TIPO_SERVICO_CODIGO) REFERENCES VEICULO_MANUTENCAO_' +
            'TIPO_SERVICO(CODIGO);'
          ''
          ''
          '-- #### LUIZ - 29/05/2025 ####'
          ''
          'CREATE TABLE VEICULO_MANUTENCAO ('
          '    CODIGO INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,'
          ''
          '    VEICULO_PLACA VARCHAR(7) NOT NULL,'
          '    MOTORISTA_CODIGO INTEGER,'
          '    FORNECEDOR_CODIGO INTEGER,'
          ''
          '    DATA_ENTRADA DATE,'
          '    HORA_ENTRADA TIME,'
          '    DATA_SAIDA DATE,'
          '    HORA_SAIDA TIME,'
          ''
          '    KM_PROXIMA_REVISAO INTEGER,'
          '    OBSERVACOES BLOB SUB_TYPE TEXT,'
          ''
          
            '    CONSTRAINT FK_MANUTENCAO_VEICULO FOREIGN KEY (VEICULO_PLACA)' +
            ' REFERENCES VEICULOS_CAVALO(PLACA),'
          
            '    CONSTRAINT FK_MANUTENCAO_MOTORISTA FOREIGN KEY (MOTORISTA_CO' +
            'DIGO) REFERENCES TRANSPORTADORA_MOTORISTA(CODIGO),'
          
            '    CONSTRAINT FK_MANUTENCAO_FORNECEDOR FOREIGN KEY (FORNECEDOR_' +
            'CODIGO) REFERENCES PESSOA(CODIGO)'
          ');'
          ''
          ''
          ''
          'CREATE TABLE VEICULO_MANUTENCAO_ITEM ('
          '    CODIGO INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,'
          ''
          '    MANUTENCAO_CODIGO INTEGER NOT NULL,'
          '    TIPO VARCHAR(20), -- '#39'PRODUTO'#39' OU '#39'SERVI'#199'O'#39
          '    DESCRICAO VARCHAR(255),'
          ''
          '    QUANTIDADE NUMERIC(10,2),'
          '    VALOR_UNITARIO NUMERIC(15,4),'
          '    DESCONTO NUMERIC(15,4),'
          '    VALOR_TOTAL COMPUTED BY ('
          '        (QUANTIDADE * VALOR_UNITARIO) - DESCONTO'
          '    ),'
          ''
          
            '    CONSTRAINT FK_MANUTENCAO_ITEM_MASTER FOREIGN KEY (MANUTENCAO' +
            '_CODIGO) REFERENCES VEICULO_MANUTENCAO(CODIGO)'
          ');'
          ''
          ''
          '-- #### LUIZ - 28/05/2025 ####'
          ''
          '-- DADOS PESSOAIS E CONTATO'
          'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD DATA_NASCIMENTO DATE;'
          'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD TELEFONE VARCHAR(20);'
          'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD WHATSAPP VARCHAR(20);'
          'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD EMAIL VARCHAR(100);'
          ''
          '-- CNH'
          
            'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD CNH_CATEGORIA VARCHAR(5' +
            ');'
          'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD CNH_DATA_EMISSAO DATE;'
          ''
          '-- EXAMES E OBSERVA'#199#213'ES'
          
            'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD EXAMES_OBSERVACOES BLOB' +
            ' SUB_TYPE TEXT;'
          
            'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD EXAMES_DATA_VENCIMENTO ' +
            'DATE;'
          ''
          '-- CAMPO DE OBSERVA'#199#213'ES GERAIS'
          
            'ALTER TABLE TRANSPORTADORA_MOTORISTA ADD OBSERVACOES BLOB SUB_TY' +
            'PE TEXT;'
          ''
          ''
          ''
          '-- #### LUIZ - 26/05/2025 ####'
          ''
          '-- SITUA'#199#195'O E AUDITORIA'
          'ALTER TABLE VEICULOS_CAVALO ADD SITUACAO VARCHAR(20);'
          'ALTER TABLE VEICULOS_CAVALO ADD DATA_CADASTRO DATE;'
          'ALTER TABLE VEICULOS_CAVALO ADD DATA_MODIFICACAO DATE;'
          'ALTER TABLE VEICULOS_CAVALO ADD USUARIO_MODIFICACAO_ID INTEGER;'
          
            'ALTER TABLE VEICULOS_CAVALO ADD CONSTRAINT FK_VEICULO_USUARIO_MO' +
            'D FOREIGN KEY (USUARIO_MODIFICACAO_ID) REFERENCES USUARIOS(CODIG' +
            'O);'
          ''
          '-- DADOS DE AQUISI'#199#195'O E ALUGUEL'
          'ALTER TABLE VEICULOS_CAVALO ADD DATA_AQUISICAO DATE;'
          'ALTER TABLE VEICULOS_CAVALO ADD VALOR_AQUISICAO NUMERIC(15,2);'
          
            'ALTER TABLE VEICULOS_CAVALO ADD VALOR_ALUGUEL_MENSAL NUMERIC(15,' +
            '2);'
          'ALTER TABLE VEICULOS_CAVALO ADD VENCIMENTO_ALUGUEL DATE;'
          ''
          '-- CARACTER'#205'STICAS GERAIS'
          'ALTER TABLE VEICULOS_CAVALO ADD MARCA VARCHAR(50);'
          'ALTER TABLE VEICULOS_CAVALO ADD MODELO VARCHAR(100);'
          'ALTER TABLE VEICULOS_CAVALO ADD COR VARCHAR(30);'
          'ALTER TABLE VEICULOS_CAVALO ADD ANO_FABRICACAO SMALLINT;'
          'ALTER TABLE VEICULOS_CAVALO ADD ANO_MODELO SMALLINT;'
          ''
          '-- DIMENS'#213'ES E PESO'
          'ALTER TABLE VEICULOS_CAVALO ADD ALTURA_METROS NUMERIC(6,2);'
          'ALTER TABLE VEICULOS_CAVALO ADD COMPRIMENTO_METROS NUMERIC(6,2);'
          'ALTER TABLE VEICULOS_CAVALO ADD LARGURA_METROS NUMERIC(6,2);'
          
            'ALTER TABLE VEICULOS_CAVALO ADD CAPACIDADE_CARGA_KG NUMERIC(10,2' +
            ');'
          
            'ALTER TABLE VEICULOS_CAVALO ADD CAPACIDADE_CARGA_M3 NUMERIC(10,2' +
            ');'
          'ALTER TABLE VEICULOS_CAVALO ADD ODOMETRO_ATUAL INTEGER;'
          ''
          ''
          '-- TRIBUTOS'
          'ALTER TABLE VEICULOS_CAVALO ADD VALOR_IPVA NUMERIC(10,2);'
          
            'ALTER TABLE VEICULOS_CAVALO ADD VALOR_LICENCIAMENTO NUMERIC(10,2' +
            ');'
          
            'ALTER TABLE VEICULOS_CAVALO ADD VALOR_SEGURO_OBRIGATORIO NUMERIC' +
            '(10,2);'
          ''
          '-- SEGURO VEICULAR'
          'ALTER TABLE VEICULOS_CAVALO ADD SEGURADORA_NOME VARCHAR(100);'
          'ALTER TABLE VEICULOS_CAVALO ADD SEGURADORA_APOLICE VARCHAR(50);'
          'ALTER TABLE VEICULOS_CAVALO ADD SEGURADORA_VALOR NUMERIC(10,2);'
          'ALTER TABLE VEICULOS_CAVALO ADD SEGURADORA_DATA_INICIO DATE;'
          'ALTER TABLE VEICULOS_CAVALO ADD SEGURADORA_DATA_VENCIMENTO DATE;'
          
            'ALTER TABLE VEICULOS_CAVALO ADD SEGURADORA_TIPO_COBERTURA VARCHA' +
            'R(50);'
          ''
          '-- OBSERVA'#199#213'ES LIVRES'
          'ALTER TABLE VEICULOS_CAVALO ADD OBSERVACOES BLOB SUB_TYPE TEXT;'
          ''
          '-- #### ALTERA'#199#213'ES ANTERIORES ####'
          ''
          'ALTER TABLE EMPRESA'
          'ADD PEDIR_COLE_ETIQUETA CHAR(1);'
          'ALTER TABLE EMPRESA'
          'ADD USA_WHATS CHAR(1);'
          'ALTER TABLE VENDAS_TERMINAIS'
          'ADD LER_PESO CHAR(1);'
          ''
          'ALTER TABLE XML_DETAIL ADD QUANT_E_TMP NUMERIC(15,2);'
          'ALTER TABLE XML_DETAIL ADD QUANT_S_TMP NUMERIC(15,2);'
          'ALTER TABLE XML_DETAIL ADD EMBALAGEM_TMP NUMERIC(15,2);'
          'ALTER TABLE XML_DETAIL ADD QTD_TOTAL_TMP NUMERIC(15,2);'
          'UPDATE XML_DETAIL '
          'SET QUANT_E_TMP = QUANT_E, '
          '    QUANT_S_TMP = QUANT_S, '
          '    EMBALAGEM_TMP = EMBALAGEM, '
          '    QTD_TOTAL_TMP = QTD_TOTAL;'
          'ALTER TABLE XML_DETAIL DROP QUANT_E;'
          'ALTER TABLE XML_DETAIL DROP QUANT_S;'
          'ALTER TABLE XML_DETAIL DROP EMBALAGEM;'
          'ALTER TABLE XML_DETAIL DROP QTD_TOTAL;'
          'ALTER TABLE XML_DETAIL ALTER QUANT_E_TMP TO QUANT_E;'
          'ALTER TABLE XML_DETAIL ALTER QUANT_S_TMP TO QUANT_S;'
          'ALTER TABLE XML_DETAIL ALTER EMBALAGEM_TMP TO EMBALAGEM;'
          'ALTER TABLE XML_DETAIL ALTER QTD_TOTAL_TMP TO QTD_TOTAL;'
          '')
        ReadOnly = True
        ScrollBars = ssVertical
        TabOrder = 0
        ExplicitWidth = 1320
        ExplicitHeight = 738
      end
    end
    object TabSheet11: TTabSheet
      Caption = 'Update Dados'
      ImageIndex = 12
      object MemoUpdate: TMemo
        Left = 0
        Top = 0
        Width = 1322
        Height = 746
        Align = alClient
        Lines.Strings = (
          'SET TERM #;'
          ''
          
            '-- Verifica se o generator GEN_VENDAS_DETALHE_ID j'#225' existe antes' +
            ' de cri'#225'-lo'
          'EXECUTE BLOCK '
          'AS '
          'DECLARE seq_exists INTEGER;'
          'BEGIN'
          '  SELECT COUNT(*) '
          '  FROM RDB$GENERATORS '
          '  WHERE RDB$GENERATOR_NAME = '#39'GEN_VENDAS_DETALHE_ID'#39
          '  INTO seq_exists;'
          '  '
          '  IF (seq_exists = 0) THEN'
          '    EXECUTE STATEMENT '#39'CREATE SEQUENCE GEN_VENDAS_DETALHE_ID'#39';'
          'END#'
          ''
          'SET TERM ;#'
          ''
          'SET TERM #;'
          ''
          
            '-- Ajusta o sequence GEN_VENDAS_DETALHE_ID para continuar do mai' +
            'or valor atual'
          'EXECUTE BLOCK    '
          'AS  '
          'DECLARE i INT = 0;    '
          'DECLARE temp INT = 0;'
          'BEGIN  '
          '  i = (SELECT COALESCE(MAX(CODIGO), 0) FROM VENDAS_DETALHE);'
          '  '
          
            '  temp = GEN_ID(GEN_VENDAS_DETALHE_ID, -(GEN_ID(GEN_VENDAS_DETAL' +
            'HE_ID, 0))); '
          '  '
          '  temp = GEN_ID(GEN_VENDAS_DETALHE_ID, :i);'
          'END#'
          ''
          'SET TERM ;#'
          ''
          'SET TERM ^ ;'
          ''
          
            '-- Criar ou alterar o trigger para gerar o c'#243'digo automaticament' +
            'e antes da inser'#231#227'o'
          'CREATE OR ALTER TRIGGER VENDAS_DETALHE_BI FOR VENDAS_DETALHE'
          'ACTIVE BEFORE INSERT POSITION 0'
          'AS'
          'BEGIN'
          '  IF (NEW.CODIGO IS NULL OR NEW.CODIGO = 0) THEN'
          '    NEW.CODIGO = GEN_ID(GEN_VENDAS_DETALHE_ID, 1);'
          'END^'
          ''
          'SET TERM ;^'
          ''
          'SET TERM #;'
          ''
          
            '-- Verifica se o generator GEN_PRE_VENDA_DETALHE_ID j'#225' existe an' +
            'tes de cri'#225'-lo'
          'EXECUTE BLOCK'
          'AS'
          'DECLARE seq_exists INTEGER;'
          'BEGIN'
          '  SELECT COUNT(*)'
          '  FROM RDB$GENERATORS'
          '  WHERE RDB$GENERATOR_NAME = '#39'GEN_PRE_VENDA_DETALHE_ID'#39
          '  INTO seq_exists;'
          ''
          '  IF (seq_exists = 0) THEN'
          
            '    EXECUTE STATEMENT '#39'CREATE SEQUENCE GEN_PRE_VENDA_DETALHE_ID'#39 +
            ';'
          'END#'
          ''
          'SET TERM ;#'
          ''
          'SET TERM #;'
          ''
          
            '-- Ajusta o sequence GEN_PRE_VENDA_DETALHE_ID para continuar do ' +
            'maior valor atual'
          'EXECUTE BLOCK'
          'AS'
          'DECLARE i INT = 0;'
          'DECLARE temp INT = 0;'
          'BEGIN'
          '  i = (SELECT COALESCE(MAX(CODIGO), 0) FROM PRE_VENDA_DETALHE);'
          ''
          
            '  temp = GEN_ID(GEN_PRE_VENDA_DETALHE_ID, -(GEN_ID(GEN_PRE_VENDA' +
            '_DETALHE_ID, 0)));'
          ''
          '  temp = GEN_ID(GEN_PRE_VENDA_DETALHE_ID, :i);'
          'END#'
          ''
          'SET TERM ;#'
          ''
          'SET TERM ^ ;'
          ''
          
            '-- Criar ou alterar o trigger para gerar o c'#243'digo automaticament' +
            'e antes da inser'#231#227'o'
          
            'CREATE OR ALTER TRIGGER PRE_VENDA_DETALHE_BI FOR PRE_VENDA_DETAL' +
            'HE'
          'ACTIVE BEFORE INSERT POSITION 0'
          'AS'
          'BEGIN'
          '  IF (NEW.CODIGO IS NULL OR NEW.CODIGO = 0) THEN'
          '    NEW.CODIGO = GEN_ID(GEN_PRE_VENDA_DETALHE_ID, 1);'
          'END^'
          ''
          'SET TERM ;^')
        ReadOnly = True
        ScrollBars = ssVertical
        TabOrder = 0
      end
    end

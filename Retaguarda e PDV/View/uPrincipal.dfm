    Connection = Dados.Conexao
    SQL.Strings = (
      
        'select  pc.id_produto, pro.descricao, pc.quantidade, pc.preco  f' +
        'rom produto_composicao pc'
      'left join produto pro on pro.codigo=pc.id_produto'
      'where'
      'pc.fk_produto=:codigo'
      'order by pro.descricao')

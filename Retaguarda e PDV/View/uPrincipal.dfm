  object qryEstoqueGrade: TFDQuery
    Connection = Dados.Conexao
    SQL.Strings = (
      
        'select  pro.codigo, pro.descricao, pg.descricao as grade, pg.qtd' +
        ', pg.preco  from produto pro'
      'left join produto_grade pg on pg.fk_produto= pro.codigo'
      'where'
      'pro.grade='#39'S'#39
      'order by descricao')
    Left = 504
    Top = 416
